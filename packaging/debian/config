# Reticulum configuration — installed by the leviculum Debian package.
# Format: Python-Reticulum INI (ConfigObj). lnsd reads this file on
# startup as `lnsd -c /etc/reticulum`.
#
# Changing this file: edit, then  sudo systemctl restart lnsd
#
# To use lns/lncp/rnstatus/rncp/etc. against the running daemon, the
# invoking user must be a member of the `leviculum` group so it can
# reach the shared-instance socket at /etc/reticulum/storage/. Add a
# user with:
#   sudo usermod -aG leviculum <username>
# …then log out and back in for the group membership to apply.

[reticulum]
enable_transport = Yes
share_instance = Yes
shared_instance_port = 37428
instance_control_port = 37429

[logging]
loglevel = 4

[interfaces]
  # The package ships with no interfaces configured. Uncomment or add
  # one of the examples below to start carrying traffic. After any
  # change:  sudo systemctl restart lnsd

