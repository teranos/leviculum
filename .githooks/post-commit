#!/bin/bash
# Skip during interactive rebase — lock+dirty handles the final state,
# but we want to reduce notification spam during rebase sessions.
GIT_DIR=$(git rev-parse --git-dir 2>/dev/null)
if [ -d "$GIT_DIR/rebase-merge" ] || [ -d "$GIT_DIR/rebase-apply" ]; then
    exit 0
fi

# Detach so commit returns immediately
nohup bash scripts/run-tier1.sh >/dev/null 2>&1 &
disown
