#!/bin/bash
set -e

# Always run Tier 0 fast checks
just fast

# Record Tier 0 pass in results log
mkdir -p ~/.local/state/leviculum-ci
echo "$(date -Iseconds) tier0 GREEN" >> ~/.local/state/leviculum-ci/last-results.txt

# Check Tier 2 staleness: 5 commits or 8h → WARN, 10 commits or 24h → BLOCK
STALENESS=$(bash scripts/check-tier2-staleness.sh)
case "$STALENESS" in
    WARN)
        echo ""
        echo "[CI] Warning: Tier 2 (extensive) hasn't run successfully recently."
        echo "[CI] Run 'just extensive' or wait for the next scheduled run (12:30 / 18:30)."
        echo ""
        ;;
    STALE)
        echo ""
        echo "[CI] Tier 2 (extensive) is stale (10+ commits or 24+ hours since last green)."
        echo "[CI] Push blocked. Run 'just extensive' first, or override with 'git push --no-verify'."
        echo ""
        exit 1
        ;;
esac
